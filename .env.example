# ── Admin credentials ──────────────────────────────────────────────────────────
JWT_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Public booking URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_BOOKING_URL=https://126222_1.holidayfuture.com/

# ── Vercel Edge Config (persistent settings & page content) ───────────────────
# Create at: Vercel Dashboard → Storage → Edge Config → Create
# Then connect to this project and copy the values below.
#
# EDGE_CONFIG     — connection string (enables Edge Config reads via SDK)
# EDGE_CONFIG_ID  — just the ID portion (e.g. ecfg_xxxx) for REST API writes
# VERCEL_ACCESS_TOKEN — Vercel API token with "Edge Config: Read/Write" scope
#
EDGE_CONFIG=
EDGE_CONFIG_ID=
VERCEL_ACCESS_TOKEN=


BLOB_READ_WRITE_TOKEN=


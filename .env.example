# ── Admin credentials ──────────────────────────────────────────────────────────
JWT_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Public booking URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_BOOKING_URL=https://126222_1.holidayfuture.com/

# ── Vercel Blob (persistent storage for settings, content, listings, uploads) ──
# Create at: Vercel Dashboard → Storage → Blob → Create Store
# Then connect to this project — BLOB_READ_WRITE_TOKEN is auto-added.
# Without this token the app falls back to local JSON files (dev mode).
#
BLOB_READ_WRITE_TOKEN=

